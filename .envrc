# Set project directories.
export PROJECT_ROOT=$(dirname "$(realpath "${BASH_SOURCE[0]}")")

# Use nix-direnv
if ! has nix_direnv_version || ! nix_direnv_version 3.0.6; then
  source_url "https://raw.githubusercontent.com/nix-community/nix-direnv/3.0.6/direnvrc" "sha256-RYcUJaRMf8oF5LznDrlCXbkOQrywm0HDv1VjYGaJGdM="
fi

# TODO: Make forge public, and use the following instead:
# use flake "github:jacob-heathorn/forge/nix"
use flake "git+ssh://git@github.com/jacob-heathorn/forge?rev=f390177dc3b00fde4ccaf114e1e7858caf5ecd85"
