{
  "version": "0.2.0",
  "configurations": [

    /*
      Steps:

      1) Use this code in your python code to listen for this attachment:

        import debugpy
        debugpy.listen(("localhost", 5678))
        print("Waiting for debugger...")
        debugpy.wait_for_client()

      2) Run the tox command with --no-cov (e.g. tox -- test/test_repository.py -s --no-cov)

      3) Run the following launch configuration

    */
    {
        "name": "Attach to python debugger",
        "type": "debugpy",
        "request": "attach",
        "connect": {
            "host": "localhost",
            "port": 5678
        },
        "justMyCode": false
    }
  ]
}